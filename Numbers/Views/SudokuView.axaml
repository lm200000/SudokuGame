<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Numbers.ViewModels"
             xmlns:converters="clr-namespace:Numbers.Converters"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="750"
             x:Class="Numbers.Views.SudokuView"
             x:DataType="vm:SudokuViewModel">
  <Design.DataContext>
    <vm:SudokuViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <Style Selector="Button.numberBtn">
      <Setter Property="Width" Value="36"/>
      <Setter Property="Height" Value="36"/>
      <Setter Property="CornerRadius" Value="18"/>
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Margin" Value="3"/>
      <Setter Property="Background" Value="#E8F5E9"/>
      <Setter Property="Foreground" Value="#2E7D32"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.numberBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#C8E6C9"/>
    </Style>
    <Style Selector="Button.numberBtn:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#A5D6A7"/>
    </Style>
    <Style Selector="Button.clearBtn">
      <Setter Property="Width" Value="36"/>
      <Setter Property="Height" Value="36"/>
      <Setter Property="CornerRadius" Value="18"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Margin" Value="6,3,3,3"/>
      <Setter Property="Background" Value="#FFEBEE"/>
      <Setter Property="Foreground" Value="#C62828"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.clearBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#FFCDD2"/>
    </Style>
    <Style Selector="Button.actionBtn">
      <Setter Property="Padding" Value="20,8"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Background" Value="#E3F2FD"/>
      <Setter Property="Foreground" Value="#1565C0"/>
    </Style>
    <Style Selector="Button.actionBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#BBDEFB"/>
    </Style>
  </UserControl.Styles>

  <Border Background="#FAFAFA" CornerRadius="0">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="10">
      
      <!-- 难度选择 + 计时器 + 新游戏 -->
      <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,10,0,15">
        <!-- 难度选择 -->
        <StackPanel Grid.Column="0" Orientation="Horizontal">
          <TextBlock Text="难度:" VerticalAlignment="Center" FontSize="14" Foreground="#546E7A" Margin="0,0,8,0"/>
          <ComboBox ItemsSource="{Binding Difficulties}" 
                    SelectedItem="{Binding SelectedDifficulty}" 
                    Width="90" FontSize="12" MinHeight="32"/>
        </StackPanel>
        
        <!-- 计时器 -->
        <Border Grid.Column="1" Background="#ECEFF1" CornerRadius="6" Padding="10,4" 
                HorizontalAlignment="Center" VerticalAlignment="Center">
          <TextBlock Text="{Binding ElapsedTime, StringFormat='{}{0:mm\\:ss}'}" 
                     FontSize="16" FontWeight="Bold" Foreground="#546E7A"/>
        </Border>
        
        <!-- 新游戏按钮 -->
        <Button Grid.Column="2" Content="新游戏" Command="{Binding NewGameCommand}" 
                Padding="16,8" FontSize="12" CornerRadius="8"
                Background="#E8F5E9" Foreground="#2E7D32" Margin="12,0,0,0"/>
      </Grid>

      <!-- Sudoku Grid -->
      <Border Grid.Row="2" BorderBrush="#263238" BorderThickness="2" 
              HorizontalAlignment="Center" CornerRadius="6" Margin="0,0,0,15"
              BoxShadow="0 4 8 0 #20000000">
        <ItemsControl ItemsSource="{Binding Cells}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <UniformGrid Columns="9" Rows="9"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border BorderBrush="#78909C">
                <Border.BorderThickness>
                  <MultiBinding Converter="{x:Static converters:CellBorderThicknessConverter.Instance}">
                    <Binding Path="IsBoxRightBorder"/>
                    <Binding Path="IsBoxBottomBorder"/>
                  </MultiBinding>
                </Border.BorderThickness>
                <Border.Background>
                  <MultiBinding Converter="{x:Static converters:CellBackgroundConverter.Instance}">
                    <Binding Path="IsSelected"/>
                    <Binding Path="IsSameValue"/>
                    <Binding Path="IsSameRowOrColOrBox"/>
                    <Binding Path="IsHighlighted"/>
                  </MultiBinding>
                </Border.Background>
                <Button Width="36" Height="36" 
                        Command="{Binding $parent[ItemsControl].((vm:SudokuViewModel)DataContext).SelectCellCommand}"
                        CommandParameter="{Binding}"
                        Background="Transparent">
                  <TextBlock Text="{Binding Value}" 
                             HorizontalAlignment="Center" 
                             VerticalAlignment="Center"
                             TextAlignment="Center"
                             FontSize="16" FontWeight="Bold">
                    <TextBlock.Foreground>
                      <MultiBinding Converter="{x:Static converters:CellTextColorConverter.Instance}">
                        <Binding Path="IsEditable"/>
                        <Binding Path="IsCorrect"/>
                      </MultiBinding>
                    </TextBlock.Foreground>
                  </TextBlock>
                </Button>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Border>

      <!-- Number Input -->
      <Border Grid.Row="3" Background="#ECEFF1" CornerRadius="10" Padding="8" HorizontalAlignment="Center" Margin="0,0,0,10">
        <StackPanel>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="1" Classes="numberBtn" Click="OnNumberButtonClick"/>
            <Button Content="2" Classes="numberBtn" Click="OnNumberButtonClick"/>
            <Button Content="3" Classes="numberBtn" Click="OnNumberButtonClick"/>
            <Button Content="4" Classes="numberBtn" Click="OnNumberButtonClick"/>
            <Button Content="5" Classes="numberBtn" Click="OnNumberButtonClick"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="4,4,0,0">
            <Button Content="6" Classes="numberBtn" Click="OnNumberButtonClick"/>
            <Button Content="7" Classes="numberBtn" Click="OnNumberButtonClick"/>
            <Button Content="8" Classes="numberBtn" Click="OnNumberButtonClick"/>
            <Button Content="9" Classes="numberBtn" Click="OnNumberButtonClick"/>
            <Button Content="✕" Classes="clearBtn" Click="OnClearButtonClick"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Action Buttons -->
      <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
        <Button Content="💡 提示" Command="{Binding HintCommand}" Classes="actionBtn" Margin="0,0,10,0"/>
        <Button Content="✓ 检查" Command="{Binding CheckCommand}" Classes="actionBtn"/>
      </StackPanel>

      <!-- Completion Overlay -->
      <Border Grid.Row="0" Grid.RowSpan="6"
              Background="#CC37474F"
              IsVisible="{Binding IsGameCompleted}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
          <TextBlock Text="🎉 恭喜完成！" FontSize="32" FontWeight="Bold" 
                     Foreground="White" HorizontalAlignment="Center"/>
          <Border Background="#ECEFF1" CornerRadius="10" Padding="15,8" Margin="0,15,0,0">
            <TextBlock Text="{Binding ElapsedTime, StringFormat='用时: {0:mm\\:ss}'}" 
                       FontSize="20" FontWeight="Bold" Foreground="#37474F" HorizontalAlignment="Center"/>
          </Border>
          <Button Content="再来一局" Command="{Binding NewGameCommand}" 
                  Margin="0,20,0,0" Padding="24,12" FontSize="14" CornerRadius="8"
                  Background="#E8F5E9" Foreground="#2E7D32"/>
        </StackPanel>
      </Border>

    </Grid>
  </Border>
</UserControl>